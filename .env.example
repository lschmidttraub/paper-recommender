# === Required ===

# At least one LLM provider key (LiteLLM reads these directly)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Email (Gmail app password — see README)
EMAIL_TO=leo.schmidttraub@gmail.com
EMAIL_FROM=leo.schmidttraub@gmail.com
GMAIL_APP_PASSWORD=

# === Models (LiteLLM format) ===

SCORING_MODEL=openrouter/anthropic/claude-haiku-4-5
BRIDGING_MODEL=openrouter/anthropic/claude-haiku-4-5

# === Optional tuning (uncomment to override defaults) ===

# Cost caps
# MAX_TOKENS_PER_BATCH=4000
# BATCH_SIZE=20

# arXiv coverage
# ARXIV_CATEGORIES=cs.LG,cs.AI,cs.CV,cs.CL,stat.ML
# ARXIV_MAX_BACKFILL_DAYS=7

# Digest sizing
# ON_INTEREST_MIN=5
# ON_INTEREST_MAX=15
# ON_INTEREST_THRESHOLD=7.0

# Surprise selection
# HF_UPVOTE_THRESHOLD=10
# HOT_SURPRISE_SCORE_MAX=5.0
# BRIDGING_SCORE_MIN=3.0
# BRIDGING_SCORE_MAX=6.0

# Run health
# MIN_SCORING_SUCCESS_RATE=0.5
